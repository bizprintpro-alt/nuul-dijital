generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== AUTH =====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  password      String?
  image         String?
  emailVerified DateTime?
  role          UserRole  @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  domains       Domain[]
  subscriptions Subscription[]
  orders        Order[]
  chatbots      ChatBot[]
  crmLeads      CRMLead[]
  tickets       Ticket[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===================== DOMAINS =====================

model Domain {
  id        String       @id @default(cuid())
  name      String       @unique
  tld       String
  userId    String?
  status    DomainStatus @default(PENDING)
  price     Int          // MNT
  expiresAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user  User?  @relation(fields: [userId], references: [id])
  order Order? @relation("DomainOrder")

  @@index([userId])
  @@map("domains")
}

// ===================== HOSTING =====================

model HostingPlan {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  type        PlanType
  description String?
  price       Int         // MNT/сар
  priceYearly Int?        // MNT/жил
  storage     Int         // GB
  bandwidth   Int         // GB/сар, 0 = unlimited
  websites    Int
  emails      Int
  features    String[]
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  subscriptions Subscription[]

  @@map("hosting_plans")
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  planId    String
  status    SubscriptionStatus @default(ACTIVE)
  startAt   DateTime           @default(now())
  endAt     DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  plan  HostingPlan @relation(fields: [planId], references: [id])
  order Order?      @relation("SubscriptionOrder")

  @@index([userId])
  @@map("subscriptions")
}

// ===================== ORDERS & PAYMENTS =====================

model Order {
  id             String      @id @default(cuid())
  userId         String
  domainId       String?     @unique
  subscriptionId String?     @unique
  type           OrderType
  amount         Int         // MNT
  status         OrderStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  domain       Domain?       @relation("DomainOrder", fields: [domainId], references: [id])
  subscription Subscription? @relation("SubscriptionOrder", fields: [subscriptionId], references: [id])
  payment      Payment?

  @@index([userId])
  @@map("orders")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  method        PaymentMethod
  transactionId String?
  amount        Int           // MNT
  status        PaymentStatus @default(PENDING)
  qpayInvoiceId String?
  qpayQrCode    String?       @db.Text
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ===================== AI CHATBOT =====================

model ChatBot {
  id        String          @id @default(cuid())
  userId    String
  name      String
  platform  ChatBotPlatform
  flowJson  String          @db.Text // JSON flow definition
  isActive  Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("chatbots")
}

// ===================== CRM =====================

model CRMLead {
  id        String    @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  company   String?
  stage     LeadStage @default(NEW)
  value     Int?      // MNT
  notes     String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("crm_leads")
}

// ===================== SUPPORT =====================

model Ticket {
  id         String       @id @default(cuid())
  userId     String
  subject    String
  message    String       @db.Text
  status     TicketStatus @default(OPEN)
  priority   Priority     @default(MEDIUM)
  aiResolved Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("tickets")
}

// ===================== ENUMS =====================

enum UserRole {
  ADMIN
  CLIENT
  RESELLER
}

enum DomainStatus {
  AVAILABLE
  PENDING
  ACTIVE
  EXPIRED
  TRANSFERRING
}

enum PlanType {
  STARTER
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum OrderType {
  DOMAIN
  HOSTING
  CHATBOT
  CRM
  DOMAIN_AND_HOSTING
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  QPAY
  SOCIALPAY
  CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ChatBotPlatform {
  FACEBOOK
  WEB
  VIBER
  TELEGRAM
}

enum LeadStage {
  NEW
  CONTACTED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
