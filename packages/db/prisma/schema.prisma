generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  domains       Domain[]
  subscriptions Subscription[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==================== DOMAINS ====================

model Domain {
  id        String       @id @default(cuid())
  name      String       @unique // e.g. "minii-biznes.mn"
  tld       String       // e.g. ".mn", ".com", ".org"
  status    DomainStatus @default(AVAILABLE)
  userId    String?
  expiresAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user  User?  @relation(fields: [userId], references: [id])
  order Order?

  @@map("domains")
}

// ==================== HOSTING ====================

model HostingPlan {
  id          String   @id @default(cuid())
  name        String   // "Starter", "Business", "Enterprise"
  slug        String   @unique
  description String?
  priceMonthly Int     // MNT, e.g. 9900
  priceYearly  Int?    // MNT, discounted
  storage     Int      // MB
  websites    Int      // max websites
  emails      Int      // max email accounts
  bandwidth   Int?     // MB/month, null = unlimited
  features    String[] // ["SSL", "Daily Backup", ...]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@map("hosting_plans")
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  planId    String
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  plan  HostingPlan @relation(fields: [planId], references: [id])
  order Order?

  @@map("subscriptions")
}

// ==================== ORDERS & PAYMENTS ====================

model Order {
  id             String        @id @default(cuid())
  userId         String
  domainId       String?       @unique
  subscriptionId String?       @unique
  type           OrderType
  amount         Int           // MNT
  status         OrderStatus   @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  domain       Domain?       @relation(fields: [domainId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  payment      Payment?

  @@map("orders")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  method        PaymentMethod
  transactionId String?       // QPay or SocialPay transaction ID
  amount        Int           // MNT
  status        PaymentStatus @default(PENDING)
  qpayInvoiceId String?       // QPay invoice ID
  qpayQrCode    String?       @db.Text // QPay QR code data
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ==================== ENUMS ====================

enum Role {
  USER
  ADMIN
}

enum DomainStatus {
  AVAILABLE
  REGISTERED
  EXPIRED
  TRANSFERRING
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  EXPIRED
}

enum OrderType {
  DOMAIN
  HOSTING
  DOMAIN_AND_HOSTING
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  QPAY
  SOCIALPAY
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
